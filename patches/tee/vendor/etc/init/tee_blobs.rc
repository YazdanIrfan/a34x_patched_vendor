# Multi-TEE init.rc script
# Support multiple firmware versions, mainly used to add support for all variants
# while running latest available firmware
# - Check the model and if the bootloader is supported via ro.boot.bootloader
# - If it is a known version it is mounted and boot process continues normally

# Credits to @salvogiangri for the initial version of this script

# SM-A346B (Europe)
on early-fs && property:ro.boot.em.model=SM-A346B && property:ro.boot.bootloader=A346BXXSBDYI1
    # TEEgris
    mount none /vendor/tee_eea /vendor/tee bind

# SM-A346E (Asia/Africa)
on early-fs && property:ro.boot.em.model=SM-A346E && property:ro.boot.bootloader=A346EXXSADYG1
    # TEEgris
    mount none /vendor/tee_sea /vendor/tee bind

# SM-A346E (Oceania)
on early-fs && property:ro.boot.em.model=SM-A346E && property:ro.boot.bootloader=A346EXXSADYH1
    # TEEgris
    mount none /vendor/tee_sea_august /vendor/tee bind

# SM-A346M (South America)
on early-fs && property:ro.boot.em.model=SM-A346M && property:ro.boot.bootloader=A346MUBSBDYI1
    # TEEgris
    mount none /vendor/tee_latam /vendor/tee bind

# SM-A346N (South Korea)
on early-fs && property:ro.boot.em.model=SM-A346N && property:ro.boot.bootloader=A346NKSSADYG1
    # TEEgris
    mount none /vendor/tee_kor /vendor/tee bind

# SM-A3460 (Taiwan/Hong Kong)
on early-fs && property:ro.boot.em.model=SM-A3460 && property:ro.boot.bootloader=A3460ZHSADYG1
    # TEEgris
    mount none /vendor/tee_chn /vendor/tee bind
